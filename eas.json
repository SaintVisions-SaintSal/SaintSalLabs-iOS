{
  "cli": {
    "version": ">= 12.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "ios": {
        "simulator": true
      }
    },
    "preview": {
      "distribution": "internal",
      "ios": {
        "simulator": false,
        "buildConfiguration": "Release"
      }
    },
    "production": {
      "autoIncrement": true,
      "ios": {
        "buildConfiguration": "Release",
        "credentialsSource": "local",
        "image": "latest"
      },
      "android": {
        "buildType": "app-bundle",
        "image": "latest",
        "env": {
          "EX_KOTLIN_VERSION": "1.9.25"
        }
      }
    }
  },
  "submit": {
    "production": {
      "ios": {
        "appleId": "ryan@saintvisiongroup.com",
        "appleTeamId": "2DG74QA62B",
        "ascAppId": "6760323011",
        "ascApiKeyIssuerId": "5cefc466-9ad9-4956-b761-683c25505aa1",
        "ascApiKeyId": "L5THU6WGBB",
        "ascApiKeyPath": "./AuthKey_L5THU6WGBB.p8"
      }
