{
  "expo": {
    "name": "SaintSal™ Labs",
    "slug": "saintsallabs",
    "version": "2.0.2",
    "description": "Elite AI intelligence platform. Research, build, and analyze across every vertical — powered by Claude, GPT, Gemini, and Grok. Patent #10,290,222.",
    "keywords": ["AI", "intelligence", "builder", "real estate", "finance", "research", "assistant"],
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "scheme": "saintsallabs",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0F0F0F"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.saintvision.saintsallabs",
      "buildNumber": "48",
      "requireFullScreen": false,
      "infoPlist": {
        "NSMicrophoneUsageDescription": "SAL Voice AI needs microphone access for real-time voice conversations.",
        "NSCameraUsageDescription": "SAL Builder can scan and analyze images for AI processing.",
        "NSPhotoLibraryUsageDescription": "Upload images to SAL Builder for AI analysis and creation.",
        "UIBackgroundModes": [
          "audio"
        ]
      },
      "config": {
        "usesNonExemptEncryption": false
      }
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "name": "SaintSal™ Labs — Elite AI Intelligence Platform",
      "shortName": "SaintSal Labs",
      "description": "Research, build, and analyze across every vertical — powered by Claude, GPT, Gemini, and Grok. Patent #10,290,222.",
      "themeColor": "#D4AF37",
      "backgroundColor": "#0F0F0F"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0F0F0F"
      },
      "package": "com.saintvision.saintsallabs"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-asset",
      "expo-font",
      "./plugins/withKotlinFix",
      [
        "expo-build-properties",
        {
          "android": {
            "kotlinVersion": "1.9.25",
            "compileSdkVersion": 35,
            "targetSdkVersion": 34,
            "minSdkVersion": 24,
            "extraMavenRepos": [],
            "enableShrinkResourcesInReleaseBuilds": false
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "af0fb455-43bc-4de1-a3e0-52db3e394651"
      }
    },
    "owner": "saint-vision-technologies-llc"
  }
}
